# Braintrust Configuration
BRAINTRUST_API_KEY=your-braintrust-api-key-here
BRAINTRUST_PROJECT=Support Desk Investigator

# LLM Provider API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ADK Configuration (Google Agent Development Kit via LiteLLM)
# Uses LiteLLM wrapper to support Anthropic Claude with ADK
# LiteLLM automatically uses ANTHROPIC_API_KEY from above
# Supported models: claude-haiku-4-5-20251001, claude-opus-4-6, etc.
ADK_MODEL=claude-haiku-4-5-20251001

# Alternative: Use Gemini models (requires GOOGLE_API_KEY)
# ADK_MODEL=gemini-2.0-flash-exp
# GOOGLE_API_KEY=your-google-api-key-here

# Frappe/ERPNext Configuration
ERPNEXT_VERSION=v16.6.0
DB_PASSWORD=123
HTTP_PUBLISH_PORT=8080

# Optional: Override site name resolution
# FRAPPE_SITE_NAME_HEADER=mysite

# Variant selection (baseline | improved)
VARIANT=baseline

# Record/Replay mode for deterministic demos (off | record | replay)
RECORD_MODE=off

# Optional: Logging
LOG_LEVEL=INFO
